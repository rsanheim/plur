# Example plur.toml configuration file
# 
# Copy this file to .plur.toml in your project root or ~/.plur.toml for global settings.
#
# Configuration precedence (highest to lowest):
# 1. Command-line flags
# 2. .plur.toml (project-specific)
# 3. ~/.plur.toml (user-specific)
# 4. Built-in defaults

# =============================================================================
# GLOBAL SETTINGS
# =============================================================================

# Number of parallel workers to use
# Default: auto-detect (number of CPU cores - 2)
workers = 4

# Enable colored output
# Default: true (auto-detected based on terminal support)
color = true

# Enable verbose output
# Default: false
verbose = false

# =============================================================================
# SPEC COMMAND SETTINGS
# Settings for 'plur spec' or just 'plur'
# =============================================================================

[spec]
# Test command to run
# Default: "bundle exec rspec"
command = "bin/rspec"

# Test framework type
# Options: "rspec" (default), "minitest"
type = "rspec"

# =============================================================================
# WATCH MODE SETTINGS
# Settings for 'plur watch'
# =============================================================================

[watch.run]
# Test command for watch mode (often skips coverage for speed)
# Default: inherits from [spec] or global settings
command = "bin/rspec --no-coverage"

# Debounce delay in milliseconds
# How long to wait after a file change before running tests
# Default: 100
debounce = 200

# Test framework type for watch mode
# Default: inherits from [spec] settings
type = "rspec"

# =============================================================================
# WATCH MAPPING SETTINGS
# Configure how files map to their test files
# =============================================================================

[watch.mappings]
# Show suggestions when no mapping is found
# Default: true
show_suggestions = true

# Provide feedback about mapping results
# Default: true
provide_feedback = true

# Custom mapping rules (evaluated before built-in rules)
# Each rule has:
# - pattern: glob or regex pattern to match files
# - target: the spec file(s) to run (can use variables)
# - description: human-readable description
# - priority: higher numbers are evaluated first (default: 50)
# - type: "glob" (default) or "regex"

[[watch.mappings.rules]]
pattern = "config/*.rb"
target = "spec/config/{name}_spec.rb"
description = "Config files to their specs"
priority = 60

[[watch.mappings.rules]]
pattern = "app/services/**/*.rb"
target = "spec/services/{path}/{name}_spec.rb"
description = "Service objects to their specs"
priority = 55

# Example: Run integration tests for certain files
[[watch.mappings.rules]]
pattern = "app/controllers/*_controller.rb"
target = "spec/requests/{name}_spec.rb"
description = "Controllers to request specs"
priority = 45

# Variables available in target:
# {file} - the full file path
# {path} - the directory path (without lib/ or app/ prefix)
# {dir} - the full directory path
# {name} - filename without extension
# {ext} - file extension without dot