# Example plur.toml configuration file
# 
# Copy this file to .plur.toml in your project root or ~/.plur.toml for global settings.
#
# Configuration precedence (highest to lowest):
# 1. Command-line flags
# 2. .plur.toml (project-specific)
# 3. ~/.plur.toml (user-specific)
# 4. Built-in defaults

# =============================================================================
# GLOBAL SETTINGS
# =============================================================================

# Number of parallel workers to use
# Default: auto-detect (number of CPU cores - 2)
workers = 4

# Enable colored output
# Default: true (auto-detected based on terminal support)
color = true

# Enable verbose output
# Default: false
verbose = false

# =============================================================================
# TASK CONFIGURATION
# Define test frameworks and custom tasks
# =============================================================================

# RSpec task configuration
[task.rspec]
# Test command to run
# Default: "bundle exec rspec"
run = "bin/rspec"

# Pattern for finding test files
# Default: "spec/**/*_spec.rb"
test_glob = "spec/**/*_spec.rb"

# Source directories to watch
# Default: ["lib", "app"]
source_dirs = ["lib", "app"]

# Minitest task configuration (if using minitest)
[task.minitest]
run = "bin/rails test"
test_glob = "test/**/*_test.rb"
source_dirs = ["lib", "app"]

# Custom task example
[task.integration]
run = "bin/rspec --tag integration"
test_glob = "spec/integration/**/*_spec.rb"
source_dirs = ["app"]

# =============================================================================
# WATCH MODE SETTINGS
# Settings for 'plur watch'
# =============================================================================

[watch.run]
# Debounce delay in milliseconds
# How long to wait after a file change before running tests
# Default: 100
debounce = 200

# =============================================================================
# WATCH MAPPING SETTINGS
# Configure how files map to their test files
# =============================================================================

[watch.mappings]
# Show suggestions when no mapping is found
# Default: true
show_suggestions = true

# Provide feedback about mapping results
# Default: true
provide_feedback = true

# Note: Mapping rules are now defined within task configurations
# You can customize mappings per task:

# Example of custom task with mappings:
# [task.custom]
# run = "bin/rspec"
# test_glob = "spec/**/*_spec.rb"
# source_dirs = ["app", "lib", "config"]
# [[task.custom.mappings]]
# pattern = "config/*.rb"
# target = "spec/config/{{name}}_spec.rb"
# [[task.custom.mappings]]
# pattern = "app/services/**/*.rb"
# target = "spec/services/{{path}}/{{name}}_spec.rb"

# Variables available in target patterns:
# {{file}} - the full file path
# {{path}} - the directory path (without lib/ or app/ prefix)
# {{name}} - filename without extension