#!/usr/bin/env ruby
# frozen_string_literal: true

#
# This file was generated by Bundler.
#
# The application 'plur-install-docker' is installed as part of a gem, and
# this file is here to facilitate running it.
#

ENV["BUNDLE_GEMFILE"] ||= File.expand_path("../Gemfile", __dir__)

bundle_binstub = File.expand_path("bundle", __dir__)

if File.file?(bundle_binstub)
  if File.read(bundle_binstub, 300).include?("This file was generated by Bundler")
    load(bundle_binstub)
  else
    abort("Your `bin/bundle` was not generated by Bundler, so this binstub cannot run.
Replace `bin/bundle` by running `bundle binstubs bundler --force`, then run this command again.")
  end
end

require "rubygems"
require "bundler/setup"
require "optimist"
require_relative "../lib/plur"
require_relative "../lib/plur/install"

# Parse options
opts = Optimist.options do
  version "plur-install-docker #{begin
    Plur.config.root_dir.join("VERSION").read.strip
  rescue
    "0.1.0"
  end}"
  banner <<~BANNER
    Install or update plur binary in a Docker container

    Usage: 
      plur-install-docker [COMMAND] SERVICE_NAME [OPTIONS]
      
    Commands:
      install   Install/update plur in container (default)
      status    Show plur installation status and doctor output

    Arguments:
      SERVICE_NAME      Name of the Docker container or service

    Options:
  BANNER

  opt :compose_prefix, "Use docker-compose naming (prefix_service_1)", type: :string, short: "C"
  opt :binary, "Path to specific binary (auto-detects if omitted)", type: :string
  opt :help, "Show this help message", short: "h"

  educate_on_error
end

# Handle help
if opts[:help]
  Optimist.educate
  exit 0
end

# Parse command and service
command = "install"
if ARGV.first && %w[install status].include?(ARGV.first)
  command = ARGV.shift
end

service = ARGV.shift
unless service
  puts "Error: SERVICE_NAME required"
  puts
  Optimist.educate
  exit 1
end

# Run the installer
installer = Plur::Install.new
installer.run(
  command: command,
  service: service,
  compose_prefix: opts[:compose_prefix],
  binary: opts[:binary]
)