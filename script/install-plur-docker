#!/usr/bin/env ruby
# frozen_string_literal: true

require "optimist"
require_relative "../lib/plur"
require_relative "../lib/plur/docker_install"

# Parse options
opts = Optimist.options do
  version "install-plur-docker #{Plur.current_git_tag}"
  banner <<~BANNER
    Install or update plur binary in a Docker container

    Usage:
      install-plur-docker [COMMAND] CONTAINER [OPTIONS]

    Commands:
      install   Install/update plur in container (default)
      status    Show plur installation status and doctor output

    Arguments:
      CONTAINER   Docker container name

    Options:
  BANNER

  opt :compose_prefix, "Use docker-compose naming (prefix_service_1)", type: :string, short: "C"
  opt :binary, "Path to specific binary (auto-detects if omitted)", type: :string
  opt :install_path, "Container path to install plur (default: /usr/local/bin)", type: :string, short: "p"
  opt :help, "Show this help message", short: "h"

  educate_on_error
end

# Handle help
if opts[:help]
  Optimist.educate
  exit 0
end

# Parse command and container
command = "install"
if ARGV.first && %w[install status].include?(ARGV.first)
  command = ARGV.shift
end

container = ARGV.shift
if container.nil?
  puts "Error: CONTAINER required"
  puts
  Optimist.educate
  exit 1
end

# Run the installer
installer = Plur::DockerInstall.new
installer.run(
  command: command,
  service: container,
  compose_prefix: opts[:compose_prefix],
  binary: opts[:binary],
  install_path: opts[:install_path]
)
