#!/usr/bin/env bash

set -e

# Check if path provided
if [ $# -eq 0 ]; then
    cat <<'EOF'
Usage: bench-streaming <project-path>

Benchmarks rux with different formatter configurations using hyperfine.

Examples:
  bench-streaming ./rux-ruby
  bench-streaming ./example-project-1234567890
  bench-streaming /path/to/ruby/project

What it does:
  - Verifies project has spec directory and dependencies
  - Runs hyperfine benchmarks comparing:
    * turbo_tests -n 8
    * rux -n 8 (dual formatter)
    * rux -n 8 --streaming-json (single streaming formatter)
  - Exports results to markdown and JSON
  - Shows performance improvements

Requirements:
  - hyperfine (brew install hyperfine)
  - rux binary in PATH with --streaming-json support
  - Ruby project with spec directory

Output:
  Creates bench-streaming-results.md and bench-streaming-results.json
EOF
    exit 1
fi

PROJECT_PATH="$1"

# Verify project path exists
if [ ! -d "$PROJECT_PATH" ]; then
    echo "Error: Project path '$PROJECT_PATH' does not exist"
    exit 1
fi

# Verify project has spec directory
if [ ! -d "$PROJECT_PATH/spec" ]; then
    echo "Error: No spec directory found in '$PROJECT_PATH'"
    exit 1
fi

# Check for required tools
if ! command -v hyperfine &> /dev/null; then
    echo "Error: hyperfine not found. Install with: brew install hyperfine"
    exit 1
fi

if ! command -v rux &> /dev/null; then
    echo "Error: rux not found. Make sure it's installed and in PATH"
    exit 1
fi

# Change to project directory
cd "$PROJECT_PATH"

# Ensure dependencies are installed
echo "Installing dependencies..."
bundle install

# Count specs for context
SPEC_COUNT=$(find spec -name "*_spec.rb" | wc -l | tr -d ' ')
echo "Found $SPEC_COUNT spec files in $(pwd)"
echo ""

echo ""
echo "Verifying commands work..."
echo "Testing turbo_tests..."
if turbo_tests --help > /dev/null 2>&1; then
    echo "✓ turbo_tests ready"
else
    echo "✗ turbo_tests failed"
    exit 1
fi

echo "Testing rux..."
if rux --help > /dev/null 2>&1; then
    echo "✓ rux ready"
else
    echo "✗ rux failed"
    exit 1
fi

echo "Testing rux --streaming-json..."
# Just test that the flag is recognized
if rux --help 2>&1 | grep -q "streaming-json" || rux --streaming-json --dry-run spec/non_existent.rb > /dev/null 2>&1; then
    echo "✓ rux streaming formatter ready"
else
    echo "✗ rux streaming formatter failed (flag may not be available)"
    # Don't exit, just skip streaming tests
fi
echo ""

# Run benchmarks
echo "Running benchmarks..."
echo "===================="

hyperfine \
    --warmup 1 \
    --runs 5 \
    --ignore-failure \
    --export-markdown bench-streaming-results.md \
    --export-json bench-streaming-results.json \
    "turbo_tests -n 8" \
    "rux -n 8" \
    "rux -n 8 --streaming-json"

cat <<EOF

Benchmark complete!
Results saved to:
  - bench-streaming-results.md (markdown table)
  - bench-streaming-results.json (detailed data)

EOF

# Show quick summary
if [ -f bench-streaming-results.md ]; then
    cat <<EOF
Quick Summary:
==============
EOF
    cat bench-streaming-results.md
fi