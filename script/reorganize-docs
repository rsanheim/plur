#!/usr/bin/env bash
set -euo pipefail

# Script to reorganize docs for MkDocs auto-navigation
# Run with --dry-run to preview changes

DRY_RUN=false
if [[ "${1:-}" == "--dry-run" ]]; then
    DRY_RUN=true
    echo "DRY RUN MODE - No changes will be made"
    echo
fi

cd "$(dirname "$0")/.."

# Helper function to execute or print commands
run_cmd() {
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "Would run: $*"
    else
        echo "Running: $*"
        "$@"
    fi
}

# Helper function to create files respecting dry-run
create_file() {
    local file_path="$1"
    local content="$2"
    
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "Would create: $file_path"
    else
        echo "Creating: $file_path"
        cat > "$file_path" << EOF
$content
EOF
    fi
}

echo "=== Reorganizing Documentation Structure ==="
echo

# 1. Create new directory structure
echo "Creating new directories..."
for dir in "docs/overview" "docs/architecture" "docs/features" "docs/development" "docs/internals"; do
    run_cmd mkdir -p "$dir"
done

# 2. Rename and move files
echo
echo "Moving and renaming files..."

# Root level moves
run_cmd git mv docs/README.md docs/index.md || true
run_cmd git mv docs/release-process.md docs/development/release-process.md || true
run_cmd git mv docs/project-status.md docs/overview/project-status.md || true

# Architecture moves
run_cmd git mv docs/architecture/cli-context-comparison.md docs/architecture/cli-design.md || true
run_cmd git mv docs/architecture/performance-tracing.md docs/architecture/performance-tracing.md || true
run_cmd git mv docs/rux-output-and-design.md docs/architecture/output-design.md || true

# Development moves
run_cmd git mv docs/development/go-vendoring-and-ci.md docs/development/go-vendoring.md || true

# Archive directory (remove underscore)
run_cmd git mv docs/_archive docs/archive || true

# 3. Create index files for each section
echo
echo "Creating section index files..."

# Overview index
create_file "docs/overview/index.md" "# Project Overview

This section provides an overview of the Rux project, its current status, and future roadmap.

## Contents

- [Project Status](project-status.md) - Current implementation status and features
- [Roadmap](roadmap.md) - Future plans and optimization strategies"

# Architecture index
create_file "docs/architecture/index.md" "# Architecture

Technical architecture documentation for Rux, covering design decisions and implementation details.

## Contents

- [CLI Design](cli-design.md) - Command-line interface design and context handling
- [Concurrency Model](concurrency-model.md) - Worker pools and goroutine management
- [Output Design](output-design.md) - Output formatting and logging strategies
- [Performance Tracing](performance-tracing.md) - Built-in performance debugging tools"

# Features index
create_file "docs/features/index.md" "# Features

Detailed documentation for Rux features and capabilities.

## Contents

- [Parallel Execution](parallel-execution.md) - Running tests in parallel
- [Watch Mode](watch-mode.md) - Automatic test re-running on file changes
- [Doctor Command](doctor-command.md) - Troubleshooting and diagnostics"

# Development index
create_file "docs/development/index.md" "# Development

Guides for contributing to and developing Rux.

## Contents

- [Contributing](contributing.md) - How to contribute to the project
- [Testing](testing.md) - Running and writing tests
- [Release Process](release-process.md) - How releases are managed
- [Go Vendoring](go-vendoring.md) - Go module vendoring and CI setup"

# Internals index
create_file "docs/internals/index.md" "# Internals

Internal implementation details and research documentation.

## Contents

- [Backspin Integration](backspin-integration.md) - Golden testing with backspin
- [File Mapping](file-mapping.md) - Configuration formats for file mapping
- [Snapshot Testing](snapshot-testing.md) - Snapshot testing approaches and patterns"

# Archive index
create_file "docs/archive/index.md" "# Archive

Historical documents, completed spikes, and deprecated documentation.

These documents are kept for historical reference but may no longer reflect the current implementation."

# 4. Extract and create new files
echo
echo "Creating extracted documentation files..."

# Extract getting started from user guide
create_file "docs/getting-started.md" "# Getting Started

Quick start guide for using Rux.

## Prerequisites

- Ruby project with RSpec tests
- Go 1.21+ (for building from source)

## Quick Install

\`\`\`bash
# From source
git clone https://github.com/rsanheim/rux-meta.git
cd rux-meta
bin/rake install

# Verify installation
rux --version
\`\`\`

## First Run

\`\`\`bash
# Run all tests with auto-detected parallelism
rux

# Run with specific number of workers
rux -n 4

# See what would run without executing
rux --dry-run
\`\`\`

For detailed installation options, see [Installation](installation.md).
For comprehensive usage information, see [Usage](usage.md)."

# Create roadmap from optimization plan
create_file "docs/overview/roadmap.md" "# Roadmap

Future plans and optimization strategies for Rux.

## Performance Optimizations

### File Grouping Strategy
- Group small test files together to reduce process overhead
- Target: 15-20% performance improvement
- Implementation: Smart bucketing algorithm

### Runtime-Based Distribution
- Track historical test runtimes
- Distribute tests based on execution time, not file count
- Ensure balanced worker loads

## Feature Additions

### Enhanced Watch Mode
- Multiple file watcher support
- Custom file mapping configurations
- Improved change detection

### Better Error Handling
- Graceful degradation on partial failures
- Detailed error reporting
- Recovery strategies

### Integration Features
- CI/CD specific optimizations
- IDE integrations
- Custom formatter support

## Technical Debt

### Code Organization
- Extract packages for better modularity
- Improve test coverage
- Performance benchmarking suite

### Documentation
- API documentation
- Plugin development guide
- Performance tuning guide"

# 5. Update mkdocs.yml to use minimal nav
echo
echo "Updating mkdocs.yml for auto-navigation..."

if [[ "$DRY_RUN" == "true" ]]; then
    echo "Would backup: mkdocs.yml to mkdocs.yml.bak"
    echo "Would update: mkdocs.yml with hybrid navigation structure"
else
    # Backup current mkdocs.yml
    echo "Backing up: mkdocs.yml to mkdocs.yml.bak"
    cp mkdocs.yml mkdocs.yml.bak
    
    # Update nav section
    echo "Creating: mkdocs.yml with new navigation"
    cat > mkdocs.yml.tmp << 'EOF'
site_name: Rux Documentation
site_description: Fast parallel test runner for Ruby/RSpec
repo_name: rsanheim/rux-meta
repo_url: https://github.com/rsanheim/rux-meta

theme:
  name: material
  font:
    text: Lato
    code: JetBrains Mono
  palette:
    - scheme: default
      primary: indigo
      accent: indigo
      toggle:
        icon: material/weather-night
        name: Switch to dark mode
    - scheme: slate
      primary: indigo
      accent: indigo
      toggle:
        icon: material/weather-sunny
        name: Switch to light mode
  features:
    - navigation.instant
    - navigation.sections
    - navigation.expand
    - navigation.indexes
    - toc.integrate
    - search.suggest
    - search.highlight
    - content.code.copy
    - content.code.annotate

markdown_extensions:
  - admonition
  - pymdownx.details
  - pymdownx.superfences:
      custom_fences:
        - name: mermaid
          class: mermaid
          format: !!python/name:pymdownx.superfences.fence_code_format
  - pymdownx.highlight:
      anchor_linenums: true
      line_spans: __span
      pygments_lang_class: true
  - pymdownx.inlinehilite
  - pymdownx.snippets
  - tables
  - toc:
      permalink: true
  - attr_list
  - md_in_html

docs_dir: docs

# Hybrid navigation - explicit section ordering with auto-discovery within sections
nav:
  - Home: index.md
  - Getting Started: getting-started.md
  - Installation: installation.md
  - Usage: usage.md
  - Configuration: configuration.md
  - Overview:
    - overview/*
  - Architecture:
    - architecture/*
  - Features:
    - features/*
  - Development:
    - development/*
  - Internals:
    - internals/*
  - Archive:
    - archive/*

plugins:
  - search
  - social

extra:
  social:
    - icon: fontawesome/brands/github
      link: https://github.com/rsanheim/rux-meta
EOF
    mv mkdocs.yml.tmp mkdocs.yml
fi

echo
echo "=== Reorganization Complete ==="
echo
echo "Next steps:"
echo "1. Review the changes with 'git status'"
echo "2. Complete any remaining file consolidations manually"
echo "3. Update internal links in markdown files"
echo "4. Test with 'script/serve-docs build'"
echo "5. Commit the changes"

if [[ "$DRY_RUN" == "true" ]]; then
    echo
    echo "This was a DRY RUN. Run without --dry-run to apply changes."
fi