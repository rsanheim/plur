#!/usr/bin/env bash
# Bootstrap development tools on a fresh macOS machine for CI
# Usage: script/ci-host-setup [--dry-run] [--help]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# Colors (disabled if not a terminal)
if [[ -t 1 ]]; then
  GREEN='\033[0;32m'
  YELLOW='\033[0;33m'
  RED='\033[0;31m'
  RESET='\033[0m'
else
  GREEN=''
  YELLOW=''
  RED=''
  RESET=''
fi

DRY_RUN=false

usage() {
  cat <<EOF
Bootstrap development tools on a fresh macOS machine.

Usage: $(basename "$0") [OPTIONS]

Options:
  --dry-run    Show what would be installed without making changes
  --help       Show this help message

Installs:
  * Xcode Command Line Tools
  * Homebrew
  * mise (version manager)
  * Ruby, Go, Python (via mise, from .mise.toml)
  * Bundler
  * CircleCI Runner (binary only, config is manual)
EOF
}

info() {
  echo -e "${GREEN}>>>${RESET} $1"
}

success() {
  echo -e "    ${GREEN}✓${RESET} $1"
}

warn() {
  echo -e "    ${YELLOW}!${RESET} $1"
}

error() {
  echo -e "    ${RED}✗${RESET} $1" >&2
}

# Parse arguments
while [[ $# -gt 0 ]]; do
  case $1 in
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1"
      usage
      exit 1
      ;;
  esac
done

if [[ "$DRY_RUN" == true ]]; then
  echo -e "${YELLOW}=== DRY RUN MODE ===${RESET}"
  echo ""
fi

# Detect platform
if [[ "$(uname)" != "Darwin" ]]; then
  error "This script is designed for macOS"
  exit 1
fi

# 1. Xcode Command Line Tools
info "Checking Xcode Command Line Tools..."
if xcode-select -p &>/dev/null; then
  success "Xcode CLT installed"
else
  if [[ "$DRY_RUN" == true ]]; then
    echo "    [dry-run] Would install Xcode Command Line Tools"
  else
    info "Installing Xcode Command Line Tools..."
    # Touch file triggers install without dialog popup
    touch /tmp/.com.apple.dt.CommandLineTools.installondemand.in-progress
    CLT_PACKAGE=$(softwareupdate -l 2>/dev/null | grep -B 1 "Command Line Tools" | grep "Label:" | sed 's/^[^:]*: //' | head -1)
    if [[ -n "$CLT_PACKAGE" ]]; then
      softwareupdate -i "$CLT_PACKAGE" --verbose
    else
      warn "Triggering interactive install (click Install when prompted)"
      xcode-select --install
      echo "    Waiting for Xcode CLT installation..."
      until xcode-select -p &>/dev/null; do
        sleep 5
      done
    fi
    rm -f /tmp/.com.apple.dt.CommandLineTools.installondemand.in-progress
    success "Xcode CLT installed"
  fi
fi

# 2. Homebrew
# Always ensure Homebrew is in PATH (may not be in fresh SSH sessions)
if [[ -f /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

info "Checking Homebrew..."
if command -v brew &>/dev/null; then
  success "Homebrew $(brew --version | head -1 | cut -d' ' -f2)"
else
  if [[ "$DRY_RUN" == true ]]; then
    echo "    [dry-run] Would install Homebrew"
  else
    info "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    # Add to PATH for this session
    if [[ -f /opt/homebrew/bin/brew ]]; then
      eval "$(/opt/homebrew/bin/brew shellenv)"
    fi
    success "Homebrew installed"
  fi
fi

# Configure Homebrew in shell profiles
BREW_SHELLENV='eval "$(/opt/homebrew/bin/brew shellenv)"'
for profile in "$HOME/.zprofile" "$HOME/.bash_profile"; do
  if [[ -f "$profile" ]] && grep -q 'brew shellenv' "$profile"; then
    success "Homebrew configured in $(basename "$profile")"
  else
    if [[ "$DRY_RUN" == true ]]; then
      echo "    [dry-run] Would add Homebrew to $(basename "$profile")"
    else
      echo '' >> "$profile"
      echo '# Homebrew' >> "$profile"
      echo "$BREW_SHELLENV" >> "$profile"
      success "Homebrew added to $(basename "$profile")"
    fi
  fi
done

# 3. mise
info "Checking mise..."
if command -v mise &>/dev/null; then
  success "mise $(mise --version 2>/dev/null | head -1)"
else
  if [[ "$DRY_RUN" == true ]]; then
    echo "    [dry-run] Would install mise via Homebrew"
  else
    info "Installing mise..."
    brew install mise
    success "mise installed"
  fi
fi

# Configure mise in shell if not already done
ZSHRC="${HOME}/.zshrc"
if [[ -f "$ZSHRC" ]] && grep -q 'mise activate' "$ZSHRC"; then
  success "mise configured in ~/.zshrc"
else
  if [[ "$DRY_RUN" == true ]]; then
    echo "    [dry-run] Would add mise activation to ~/.zshrc"
  else
    info "Configuring mise in ~/.zshrc..."
    echo '' >> "$ZSHRC"
    echo '# mise (version manager)' >> "$ZSHRC"
    echo 'eval "$(mise activate zsh)"' >> "$ZSHRC"
    success "mise configured in ~/.zshrc"
  fi
fi

# Activate mise for this session
if command -v mise &>/dev/null && [[ "$DRY_RUN" == false ]]; then
  eval "$(mise activate bash)"
fi

# 4. Install tools from .mise.toml
info "Installing tools from .mise.toml..."
cd "$PROJECT_ROOT"

if [[ "$DRY_RUN" == true ]]; then
  mise install --dry-run
else
  mise trust "$PROJECT_ROOT"
  mise install --yes
  success "Tools installed"
fi

# 5. Bundler
info "Checking Bundler..."
if [[ "$DRY_RUN" == true ]]; then
  echo "    [dry-run] Would install bundler gem"
else
  cd "$PROJECT_ROOT"

  # Check if bundler is installed for the mise-managed Ruby
  BUNDLER_VERSION=$(mise exec -- gem list bundler --exact 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1)
  if [[ -n "$BUNDLER_VERSION" ]]; then
    success "bundler $BUNDLER_VERSION"
  else
    info "Installing Bundler..."
    mise exec -- gem install bundler
    success "bundler installed"
  fi
fi

# 6. CircleCI Runner (for CI VMs)
info "Checking CircleCI Runner..."
if command -v circleci-runner &>/dev/null; then
  success "circleci-runner installed"
else
  if [[ "$DRY_RUN" == true ]]; then
    echo "    [dry-run] Would install circleci-runner"
  else
    info "Installing CircleCI Runner..."
    brew tap circleci-public/circleci
    brew install circleci-runner
    # Clear macOS quarantine
    sudo xattr -r -d com.apple.quarantine "$(brew --prefix)/bin/circleci-runner" 2>/dev/null || true
    success "circleci-runner installed"
  fi
fi

# Summary
echo ""
info "Setup complete!"
echo ""
if [[ "$DRY_RUN" == false ]]; then
  cd "$PROJECT_ROOT"

  echo "Installed versions:"
  echo "  ruby    $(mise exec -- ruby --version 2>/dev/null | cut -d' ' -f2 || echo 'not found')"
  echo "  go      $(mise exec -- go version 2>/dev/null | cut -d' ' -f3 | sed 's/go//' || echo 'not found')"
  echo "  python  $(mise exec -- python --version 2>/dev/null | cut -d' ' -f2 || echo 'not found')"
  echo "  bundler $(mise exec -- bundle --version 2>/dev/null | cut -d' ' -f3 || echo 'not found')"
  echo ""
  echo "Run 'source ~/.zshrc' or start a new shell to use mise-managed tools."
fi
