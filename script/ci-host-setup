#!/usr/bin/env bash
#
# Plur CI host setup - project-specific tools for the CI VM
#
# Assumes base tooling (Xcode CLT, Homebrew, mise) is already installed.
# Run 'vm-bootstrap' first if starting from a fresh VM.
#
# Usage: script/ci-host-setup [--dry-run] [--help]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# Colors (disabled if not a terminal)
if [[ -t 1 ]]; then
  GREEN='\033[0;32m'
  YELLOW='\033[0;33m'
  RED='\033[0;31m'
  RESET='\033[0m'
else
  GREEN=''
  YELLOW=''
  RED=''
  RESET=''
fi

DRY_RUN=false

usage() {
  cat <<EOF
Plur CI host setup - installs project-specific tools for CI.

Usage: $(basename "$0") [OPTIONS]

Options:
  --dry-run    Show what would be installed without making changes
  --help       Show this help message

Prerequisite:
  Base tooling must be installed first. Run 'vm-bootstrap' if on a fresh VM.

Installs:
  * Ruby, Go, Python (via mise, from .mise.toml)
  * Bundler
  * CircleCI Runner
  * GoReleaser
EOF
}

info() {
  echo -e "${GREEN}>>>${RESET} $1"
}

success() {
  echo -e "    ${GREEN}✓${RESET} $1"
}

warn() {
  echo -e "    ${YELLOW}!${RESET} $1"
}

error() {
  echo -e "    ${RED}✗${RESET} $1" >&2
}

# Parse arguments
while [[ $# -gt 0 ]]; do
  case $1 in
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1"
      usage
      exit 1
      ;;
  esac
done

if [[ "$DRY_RUN" == true ]]; then
  echo -e "${YELLOW}=== DRY RUN MODE ===${RESET}"
  echo ""
fi

# Detect platform
if [[ "$(uname)" != "Darwin" ]]; then
  error "This script is designed for macOS"
  exit 1
fi

# Ensure Homebrew is in PATH
if [[ -f /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# Check prerequisites
info "Checking prerequisites..."
if ! command -v brew &>/dev/null; then
  error "Homebrew not found. Run 'vm-bootstrap' first."
  exit 1
fi
success "Homebrew available"

if ! command -v mise &>/dev/null; then
  error "mise not found. Run 'vm-bootstrap' first."
  exit 1
fi
success "mise available"

# Activate mise for this session
eval "$(mise activate bash)"

# 1. Install tools from .mise.toml
info "Installing tools from .mise.toml..."
cd "$PROJECT_ROOT"

if [[ "$DRY_RUN" == true ]]; then
  mise install --dry-run
else
  mise trust "$PROJECT_ROOT"
  mise install --yes
  success "Tools installed"
fi

# 2. Bundler
info "Checking Bundler..."
if [[ "$DRY_RUN" == true ]]; then
  echo "    [dry-run] Would install bundler gem"
else
  cd "$PROJECT_ROOT"

  # Check if bundler is installed for the mise-managed Ruby
  BUNDLER_VERSION=$(mise exec -- gem list bundler --exact 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1)
  if [[ -n "$BUNDLER_VERSION" ]]; then
    success "bundler $BUNDLER_VERSION"
  else
    info "Installing Bundler..."
    mise exec -- gem install bundler
    success "bundler installed"
  fi
fi

# 3. CircleCI Runner
info "Checking CircleCI Runner..."
if command -v circleci-runner &>/dev/null; then
  success "circleci-runner installed"
else
  if [[ "$DRY_RUN" == true ]]; then
    echo "    [dry-run] Would install circleci-runner"
  else
    info "Installing CircleCI Runner..."
    brew tap circleci-public/circleci
    brew install circleci-runner
    # Clear macOS quarantine
    sudo xattr -r -d com.apple.quarantine "$(brew --prefix)/bin/circleci-runner" 2>/dev/null || true
    success "circleci-runner installed"
  fi
fi

# 4. GoReleaser
info "Checking GoReleaser..."
if command -v goreleaser &>/dev/null; then
  success "goreleaser $(goreleaser --version 2>/dev/null | head -1 | awk '{print $NF}')"
else
  if [[ "$DRY_RUN" == true ]]; then
    echo "    [dry-run] Would install goreleaser"
  else
    info "Installing GoReleaser..."
    brew install goreleaser
    success "goreleaser installed"
  fi
fi

# Summary
echo ""
info "Plur CI setup complete!"
echo ""
if [[ "$DRY_RUN" == false ]]; then
  cd "$PROJECT_ROOT"

  echo "Installed versions:"
  echo "  ruby         $(mise exec -- ruby --version 2>/dev/null | cut -d' ' -f2 || echo 'not found')"
  echo "  go           $(mise exec -- go version 2>/dev/null | cut -d' ' -f3 | sed 's/go//' || echo 'not found')"
  echo "  python       $(mise exec -- python --version 2>/dev/null | cut -d' ' -f2 || echo 'not found')"
  echo "  bundler      $(mise exec -- bundle --version 2>/dev/null | cut -d' ' -f3 || echo 'not found')"
  echo "  goreleaser   $(goreleaser --version 2>/dev/null | head -1 | awk '{print $NF}' || echo 'not found')"
  echo ""
  echo "Run 'source ~/.zshrc' or start a new shell to use mise-managed tools."
fi
