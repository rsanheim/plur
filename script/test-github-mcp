#!/usr/bin/env bash
set -euo pipefail

# Test script for GitHub MCP server with 1Password integration
# This mimics what Claude Code will run based on .mcp.json

echo "Testing GitHub MCP server with 1Password integration..."
echo "============================================"

# Check prerequisites
command -v op >/dev/null 2>&1 || { echo "Error: 'op' CLI not found. Please install 1Password CLI."; exit 1; }
command -v docker >/dev/null 2>&1 || { echo "Error: 'docker' not found. Please install Docker."; exit 1; }

# Test 1Password token access
echo -n "Testing 1Password token access... "
if GITHUB_PERSONAL_ACCESS_TOKEN=$(op read "op://Private/github-mcp-rux-meta/credential" 2>/dev/null); then
    echo "✓ Success"
    echo "Token starts with: ${GITHUB_PERSONAL_ACCESS_TOKEN:0:7}..."
else
    echo "✗ Failed"
    echo "Could not read token from 1Password. Check:"
    echo "  - You're signed into 1Password CLI (run: op signin)"
    echo "  - The path 'op://Private/github-mcp-rux-meta/credential' is correct"
    echo "  - Try: op item list --vault Private | grep github"
    exit 1
fi

# Test Docker image
echo -n "Checking Docker image... "
if docker image inspect ghcr.io/github/github-mcp-server:latest >/dev/null 2>&1; then
    echo "✓ Found"
else
    echo "✗ Not found"
    echo "Pulling image..."
    docker pull ghcr.io/github/github-mcp-server:latest
fi

# Run the actual command that MCP will use
echo -e "\nRunning MCP server (press Ctrl+C to stop)..."
echo "This replicates the exact command from .mcp.json"
echo "============================================"

# Set the token in env for op run
export GITHUB_PERSONAL_ACCESS_TOKEN="op://Private/github-mcp-rux-meta/credential"

# Run exactly as configured in .mcp.json
op run -- docker run -i --rm \
    -e GITHUB_PERSONAL_ACCESS_TOKEN \
    ghcr.io/github/github-mcp-server:latest