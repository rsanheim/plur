#!/usr/bin/env bash

# Script to benchmark rux with and without tracing enabled

set -e

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "Benchmarking rux with and without tracing..."
echo

# Navigate to project directory
PROJECT_DIR="${1:-./references/example-project}"

if [ ! -d "$PROJECT_DIR" ]; then
    echo "Error: Project directory not found: $PROJECT_DIR"
    echo "Usage: $0 [project_directory]"
    exit 1
fi

cd "$PROJECT_DIR"

# Get rux binary path
RUX_BINARY="$(pwd)/../../rux/rux"
if [ ! -f "$RUX_BINARY" ]; then
    echo "Error: rux binary not found at $RUX_BINARY"
    echo "Please build rux first: cd rux && go build"
    exit 1
fi

# Number of runs for averaging
RUNS=5

echo "Project: $PROJECT_DIR"
echo "Runs per test: $RUNS"
echo

# Function to run and time a command multiple times
run_benchmark() {
    local name=$1
    local cmd=$2
    local times=()
    
    echo -e "${YELLOW}Running: $name${NC}"
    
    for i in $(seq 1 $RUNS); do
        # Redirect output to /dev/null to reduce noise
        start=$(date +%s.%N)
        eval "$cmd" > /dev/null 2>&1
        end=$(date +%s.%N)
        
        # Calculate elapsed time
        elapsed=$(echo "$end - $start" | bc)
        times+=($elapsed)
        echo "  Run $i: ${elapsed}s"
    done
    
    # Calculate average
    total=0
    for t in "${times[@]}"; do
        total=$(echo "$total + $t" | bc)
    done
    avg=$(echo "scale=3; $total / $RUNS" | bc)
    
    echo -e "${GREEN}  Average: ${avg}s${NC}"
    echo
    
    # Return average for comparison
    echo $avg
}

# Test with different worker counts
for workers in 2 4 8; do
    echo "=== Testing with $workers workers ==="
    
    # Without tracing
    avg_no_trace=$(run_benchmark "rux -n $workers (no trace)" "$RUX_BINARY -n $workers")
    
    # With tracing
    avg_trace=$(run_benchmark "rux -n $workers --trace" "$RUX_BINARY -n $workers --trace")
    
    # Calculate overhead
    overhead=$(echo "scale=1; (($avg_trace - $avg_no_trace) / $avg_no_trace) * 100" | bc)
    
    echo -e "${YELLOW}Summary for $workers workers:${NC}"
    echo "  Without trace: ${avg_no_trace}s"
    echo "  With trace:    ${avg_trace}s"
    echo -e "  Overhead:      ${GREEN}${overhead}%${NC}"
    echo
done

echo "Benchmark complete!"