#!/usr/bin/env ruby

require "json"
require "optparse"
require "open3"

# Parse command line options for testing
options = {}
OptionParser.new do |opts|
  opts.banner = "Usage: cc-post-tool-use [options]"
  opts.on("-f", "--file PATH", "File path to test (for direct testing)") do |f|
    options[:file] = f
  end
  opts.on("-v", "--verbose", "Verbose output") do
    options[:verbose] = true
  end
end.parse!

# Get file path from command line option or JSON input
file_path = options[:file]

unless file_path
  # Parse JSON input from stdin
  begin
    raw_input = $stdin.read
    input = JSON.parse(raw_input)
  rescue JSON::ParserError => e
    warn "Error parsing JSON input: #{e.message}"
    warn "Raw input received:"
    warn raw_input
    exit 0  # Exit gracefully to not block Claude
  end

  # Extract file path from tool execution
  file_path = input.dig("tool_input", "file_path")

  # Log if the expected structure is missing
  if input && !file_path
    warn "Warning: Could not find file_path in expected location (tool_input.file_path)"
    warn "Input structure: #{input.keys.join(", ")}"
  end
end

exit 0 unless file_path

puts "Processing file: #{file_path}" if options[:verbose]

# Convert to relative path if possible
file_path = begin
  Pathname.new(file_path).relative_path_from(Pathname.pwd).to_s
rescue
  file_path
end

# Map file to its corresponding test
def find_test_for(file_path)
  case file_path
  when /\.go$/
    # Go file - find corresponding test file
    if file_path.end_with?("_test.go")
      # Already a test file
      [file_path]
    else
      # Look for test file
      test_file = file_path.sub(/\.go$/, "_test.go")
      File.exist?(test_file) ? [test_file] : []
    end
  when /\.rb$/
    # Ruby file - find corresponding spec
    if file_path.end_with?("_spec.rb")
      # Already a spec file
      [file_path]
    elsif file_path.start_with?("lib/")
      # lib/foo.rb -> spec/foo_spec.rb
      spec_file = file_path.sub(/^lib\//, "spec/").sub(/\.rb$/, "_spec.rb")
      File.exist?(spec_file) ? [spec_file] : []
    elsif file_path.start_with?("app/")
      # app/models/foo.rb -> spec/models/foo_spec.rb
      spec_file = file_path.sub(/^app\//, "spec/").sub(/\.rb$/, "_spec.rb")
      File.exist?(spec_file) ? [spec_file] : []
    elsif file_path.start_with?("plur/")
      # plur/foo.go -> plur/foo_test.go
      test_file = file_path.sub(/\.rb$/, "_spec.rb")
      File.exist?(test_file) ? [test_file] : []
    else
      []
    end
  else
    []
  end
end

# Find tests for the modified file
tests = find_test_for(file_path)

if tests.empty?
  puts "No tests found for #{file_path}" if options[:verbose]
  exit 0
end

# Run the tests and track results
all_passed = true
failed_outputs = []

tests.each do |test_file|
  puts "Running test: #{test_file}"

  cmd = case test_file
  when /\.go$/
    # Run Go test
    dir = File.dirname(test_file)
    "cd #{dir} && go test -v -run Test"
  when /_spec\.rb$/
    # Run RSpec test
    "bundle exec rspec #{test_file}"
  end

  # Capture stdout, stderr, and exit status
  stdout, stderr, status = Open3.capture3(cmd)

  if status.success?
    # Print output for successful tests in verbose mode
    puts stdout if options[:verbose]
  else
    # Store failed test output
    all_passed = false
    failed_outputs << {
      test_file: test_file,
      command: cmd,
      stdout: stdout,
      stderr: stderr,
      exit_code: status.exitstatus
    }
  end
end

# Exit code 2 blocks further processing if tests fail
# Exit code 0 allows processing to continue
if all_passed
  puts "✓ All tests passed" if options[:verbose]
  exit 0
else
  # Print all failure details to stderr for Claude to see
  warn "✗ Tests failed for #{file_path}"
  warn ""

  failed_outputs.each do |failure|
    warn "=" * 60
    warn "Test failed: #{failure[:test_file]}"
    warn "Command: #{failure[:command]}"
    warn "Exit code: #{failure[:exit_code]}"
    warn "-" * 40
    warn "STDOUT:"
    warn failure[:stdout]
    warn "-" * 40
    warn "STDERR:"
    warn failure[:stderr]
    warn "=" * 60
  end

  # Exit with code 2 to block Claude Code on test failures
  exit 2
end
