#!/usr/bin/env bash
set -euo pipefail

# script/benchstat - Run Go benchmarks with benchstat comparison
#
# Usage:
#   script/benchstat                        # Run all, save timestamped results
#   script/benchstat --compare old.txt      # Compare against baseline
#   script/benchstat --filter Grouper       # Only Grouper benchmarks
#   script/benchstat --count 10             # 10 iterations for statistical significance
#   script/benchstat --list                 # List available benchmarks
#
# Examples:
#   script/benchstat --count 5 --filter RSpec
#   script/benchstat --compare results/benchmarks/baseline.txt
#
# Results are saved to: results/benchmarks/<timestamp>-bench.txt

RESULTS_DIR="results/benchmarks"
COUNT="${BENCHSTAT_COUNT:-5}"
FILTER=""
COMPARE_FILE=""
LIST_ONLY=false

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --count)
            COUNT="$2"
            shift 2
            ;;
        --filter)
            FILTER="$2"
            shift 2
            ;;
        --compare)
            COMPARE_FILE="$2"
            shift 2
            ;;
        --list)
            LIST_ONLY=true
            shift
            ;;
        -h|--help)
            echo "Usage: script/benchstat [OPTIONS]"
            echo ""
            echo "Options:"
            echo "  --count N        Run N iterations (default: 5)"
            echo "  --filter REGEX   Only run benchmarks matching REGEX"
            echo "  --compare FILE   Compare new results against FILE"
            echo "  --list           List available benchmarks"
            echo "  -h, --help       Show this help"
            echo ""
            echo "Environment:"
            echo "  BENCHSTAT_COUNT  Default iteration count (default: 5)"
            echo ""
            echo "Results are saved to: results/benchmarks/<timestamp>-bench.txt"
            exit 0
            ;;
        *)
            echo "Unknown option: $1"
            exit 1
            ;;
    esac
done

# Ensure benchstat is installed
if ! command -v benchstat &> /dev/null; then
    echo "Installing benchstat..."
    go install golang.org/x/perf/cmd/benchstat@latest
fi

mkdir -p "$RESULTS_DIR"

# List mode
if [ "$LIST_ONLY" = true ]; then
    echo "Available benchmarks:"
    go test -list 'Benchmark.*' 2>/dev/null | grep -E '^Benchmark' | sort
    exit 0
fi

# Build the benchmark filter
BENCH_PATTERN="."
if [ -n "$FILTER" ]; then
    BENCH_PATTERN="$FILTER"
fi

TIMESTAMP=$(date +%Y%m%d-%H%M%S)
OUTPUT_FILE="$RESULTS_DIR/${TIMESTAMP}-bench.txt"

echo "Running benchmarks..."
echo "  Filter: ${FILTER:-all}"
echo "  Count:  $COUNT iterations"
echo ""

# Run benchmarks
go test -bench="$BENCH_PATTERN" -benchmem -count="$COUNT" -run='^$' 2>&1 | tee "$OUTPUT_FILE"

echo ""
echo "Results saved to: $OUTPUT_FILE"

# If comparison file provided, run benchstat
if [ -n "$COMPARE_FILE" ]; then
    echo ""
    echo "Comparing against $COMPARE_FILE..."
    echo ""
    benchstat "$COMPARE_FILE" "$OUTPUT_FILE"
else
    echo ""
    echo "To compare with a baseline:"
    echo "  benchstat <old.txt> $OUTPUT_FILE"
fi
