#!/usr/bin/env bash
set -euo pipefail

# Fail if downstream production code uses forbidden raw-config fields or legacy helpers.
# Files checked: command handlers and watch_find.
found=0

for pattern in \
  'autodetect\.(ResolveJob|ValidateConfig)' \
  'watch\.ValidateConfig' \
  'loadWatchConfiguration' \
  ; do
  if rg -n "$pattern" cmd_*.go watch_find.go 2>/dev/null; then
    found=1
  fi
done

if [ "$found" -eq 1 ]; then
  echo "FAIL: legacy config resolution found in command handlers"
  exit 1
fi
