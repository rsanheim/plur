#!/usr/bin/env bash

set -e

# Default values
ORIGINAL_DIR=$(pwd)
RESULTS_DIR="$ORIGINAL_DIR/results"
WORKERS=8
WARMUP=2
RUNS=5
TIMESTAMP=${BENCH_TIMESTAMP:-$(date -u +"%Y%m%d-%H%M%S")}
ENABLE_TRACE=false
SAVE_RESULTS=true

# Help function
show_help() {
    cat << EOF
Usage: $0 [OPTIONS]

Benchmark rux vs turbo_tests performance on Ruby projects.

OPTIONS:
    -p, --project PATH     Path to Ruby project to benchmark (can be used multiple times)
    -n, --workers NUM      Number of workers to use (default: $WORKERS)
    --no-results           Don't save results to file
    --warmup NUM           Number of warmup runs (default: $WARMUP)
    --show-output          Show output of each benchmark run
    --runs NUM             Number of benchmark runs (default: $RUNS)
    --trace                Enable rux tracing for performance analysis
    -h, --help             Show this help message

EXAMPLES:
    # Benchmark default projects (default-ruby and example-project)
    $0

    # Benchmark a specific project with 4 workers
    $0 -p ./references/example-project -n 4

    # Benchmark multiple projects
    $0 -p ./project1 -p ./project2 -n 8

    # Enable tracing for performance analysis
    $0 -p ./references/example-project --trace

ENVIRONMENT:
    BENCH_TIMESTAMP        Override the timestamp used for output files

OUTPUT:
    Results are saved to: $RESULTS_DIR/
EOF
    exit 0
}

# Parse command line arguments
PROJECT_PATHS=()
while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help)
            show_help
            ;;
        --trace)
            ENABLE_TRACE=true
            shift
            ;;
        -n|--workers)
            WORKERS="$2"
            shift 2
            ;;
        --warmup)
            WARMUP="$2"
            shift 2
            ;;
        --runs)
            RUNS="$2"
            shift 2
            ;;
        -p|--project)
            PROJECT_PATHS+=("$2")
            shift 2
            ;;
        --no-results)
            SAVE_RESULTS=false
            shift
            ;;
        *)
            echo "Error: Unknown option: $1"
            echo "Use -h or --help for usage information"
            exit 1
            ;;
    esac
done

die() {
    echo "Error: $1"
    exit 1
}

# Get current git SHA
GIT_SHA=$(git rev-parse --short HEAD || echo "nogit")

# Get rux version
RUX_VERSION=$("$ORIGINAL_DIR/rux/rux" --version 2>/dev/null || echo "rux version unknown")

# Function to benchmark a single project
benchmark_project() {
    local project_path=$1
    local project_name=$(basename "$project_path")
    
    echo ""
    echo "=== Benchmarking $project_name ==="
    
    pushd "$project_path" > /dev/null || die "Could not change to project directory: $project_path"
    
    SPEC_COUNT=$(find spec -name "*_spec.rb" 2>/dev/null | wc -l | tr -d ' ')
    echo "Found $SPEC_COUNT spec files"
    
    # Output file in results directory
    JSON_FILE="$RESULTS_DIR/${TIMESTAMP}-${GIT_SHA}-${project_name}.json"
    
    # Run benchmarks
    echo "Running benchmarks with $WORKERS workers, $WARMUP warmup runs, $RUNS runs"
    echo "Rux version: $RUX_VERSION"
    if [ "$ENABLE_TRACE" = true ]; then
        echo "Tracing: ENABLED"
    fi
    echo "===================="
    
    # Build rux command with optional trace flag
    RUX_CMD="$ORIGINAL_DIR/rux/rux -n $WORKERS"
    if [ "$ENABLE_TRACE" = true ]; then
        RUX_CMD="$RUX_CMD --trace"
    fi
    
    if [ "$SAVE_RESULTS" = true ]; then
    hyperfine \
        --warmup $WARMUP \
        --runs $RUNS \
        --export-json "$JSON_FILE" \
        --show-output \
            "turbo_tests -n $WORKERS" \
            "$RUX_CMD"
    else
        hyperfine \
            --warmup $WARMUP \
            --runs $RUNS \
            --show-output \
            "turbo_tests -n $WORKERS" \
            "$RUX_CMD"
    fi
    
    # Add version info to JSON file
    if [ -f "$JSON_FILE" ]; then
        # Use jq to add version info if available, otherwise append as comment
        if command -v jq >/dev/null 2>&1; then
            mv "$JSON_FILE" "$JSON_FILE.tmp"
            jq --arg version "$RUX_VERSION" '. + {rux_version: $version}' "$JSON_FILE.tmp" > "$JSON_FILE"
            rm "$JSON_FILE.tmp"
        else
            # Append version as JSON comment (non-standard but preserves info)
            echo "" >> "$JSON_FILE"
            echo "// rux_version: $RUX_VERSION" >> "$JSON_FILE"
        fi
    fi
    
    if [ "$SAVE_RESULTS" = true ]; then
        echo ""
        echo "Results saved to:"
        echo "  - $JSON_FILE"
    fi

    # Analyze trace files if tracing was enabled
    if [ "$ENABLE_TRACE" = true ]; then
        echo ""
        echo "Analyzing trace files..."
        
        # Find the most recent trace files (from the last run)
        TRACE_DIR="$ORIGINAL_DIR/tmp/rux-traces"
        if [ -d "$TRACE_DIR" ]; then
            # Get the 3 most recent trace files (matching the number of runs)
            RECENT_TRACES=$(ls -t "$TRACE_DIR"/rux-trace-*.json 2>/dev/null | head -$RUNS)
            
            if [ -n "$RECENT_TRACES" ]; then
                echo "Found trace files:"
                for trace in $RECENT_TRACES; do
                    echo "  - $(basename $trace)"
                    
                    # Run trace analysis
                    if [ -f "$ORIGINAL_DIR/rux/analyze_trace.rb" ]; then
                        echo "    Analysis:"
                        ruby "$ORIGINAL_DIR/rux/analyze_trace.rb" "$trace" | grep -E "(Rux overhead:|Total execution time:|Longest spec file:)" | sed 's/^/    /'
                    fi
                done
                
                # Save trace file paths to results
                TRACE_LIST_FILE="$RESULTS_DIR/${TIMESTAMP}-${GIT_SHA}-${project_name}-traces.txt"
                echo "$RECENT_TRACES" > "$TRACE_LIST_FILE"
                echo "  - $TRACE_LIST_FILE"
            fi
        fi
    fi
    
    popd > /dev/null
}

# Create results directory
mkdir -p "$RESULTS_DIR"

# Check if custom project paths were provided
if [ ${#PROJECT_PATHS[@]} -gt 0 ]; then
    # Benchmark custom projects
    for project in "${PROJECT_PATHS[@]}"; do
        if [ -d "$project" ]; then
            benchmark_project "$project"
        else
            echo "Warning: Directory not found: $project"
        fi
    done
else
    # Run default benchmarks
    echo "Running benchmarks for default-ruby and example-project"
    
    benchmark_project "./fixtures/projects/default-ruby"
    benchmark_project "./references/example-project"
fi

echo ""
echo "All benchmarks complete!"
if [ "$ENABLE_TRACE" = true ]; then
    echo "Trace files saved to: $ORIGINAL_DIR/tmp/rux-traces/"
fi
