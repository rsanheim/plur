#!/usr/bin/env ruby

require "optparse"
require_relative "../lib/plur/benchmark"

config = Plur::Benchmark::Config.new

OptionParser.new do |opts|
  opts.banner = "Usage: bench [OPTIONS]"
  opts.separator ""
  opts.separator "Benchmark rux vs turbo_tests performance on Ruby projects."
  opts.separator ""
  opts.separator "OPTIONS:"

  opts.on("-p", "--project PATH", "Path to Ruby project to benchmark (can be used multiple times)") do |path|
    config.projects << path
  end

  opts.on("-n", "--workers NUM", Integer, "Number of workers to use (default: #{config.workers})") do |n|
    config.workers = n
  end

  opts.on("--checkpoint", "Create summary files combining multiple project results") do
    config.checkpoint = true
  end

  opts.on("--warmup NUM", Integer, "Number of warmup runs (default: #{config.warmup})") do |n|
    config.warmup = n
  end

  opts.on("--runs NUM", Integer, "Number of benchmark runs (default: #{config.runs})") do |n|
    config.runs = n
  end

  opts.on("--min-runs NUM", Integer, "Minimum number of runs for each command") do |n|
    config.min_runs = n
  end

  opts.on("--max-runs NUM", Integer, "Maximum number of runs for each command") do |n|
    config.max_runs = n
  end


  opts.on("--no-results", "Don't save results to file") do
    config.save_results = false
  end

  opts.on("--show-output", "Show output of each benchmark run") do
    config.show_output = true
  end

  opts.on("-h", "--help", "Show this help message") do
    puts opts
    puts <<~HELP

      EXAMPLES:
          # Benchmark default projects (default-ruby and example-project)
          bench

          # Create checkpoint with summary (combines results from all projects)
          bench --checkpoint

          # Benchmark a specific project with 4 workers
          bench -p ./references/example-project -n 4

          # Benchmark multiple projects
          bench -p ./project1 -p ./project2 -n 8

          bench -p ./references/example-project

      ENVIRONMENT:
          BENCH_TIMESTAMP        Override the timestamp used for output files

      OUTPUT:
          Results are saved to: #{config.results_dir}/
    HELP
    exit 0
  end
end.parse!

# Show configuration
commit = begin
  `git rev-parse --short HEAD`.strip
rescue
  "unknown"
end

puts <<~CONFIG
  Benchmark Configuration
  ======================
  Commit: #{commit}
  Time: #{config.timestamp}
  Workers: #{config.workers}
  Projects: #{config.projects_to_benchmark.map { |p| File.basename(p) }.join(", ")}
  
CONFIG

# Run benchmarks
runner = Plur::Benchmark::Runner.new(config)
runner.run

puts "\nAll benchmarks complete!"

if !config.checkpoint && config.save_results
  puts "\nTip: Use --checkpoint to create a combined summary of all results"
end
