#!/usr/bin/env ruby

# Analyze the performance difference between turbo_tests and rux
# Specifically testing different command strategies

require "json"
require "fileutils"

project_path = File.expand_path("../references/example-project", __dir__)
results_dir = File.expand_path("../results", __dir__)
workers = 4

FileUtils.mkdir_p(results_dir)

Dir.chdir(project_path) do
  puts "=== Performance Analysis: turbo_tests vs rux ==="
  puts "Project: example-project"
  puts "Workers: #{workers}"
  puts "=" * 50

  timestamp = Time.now.strftime("%Y%m%d-%H%M%S")
  
  # Test 1: Compare default behaviors
  puts "\n1. Testing default behaviors..."
  json_file = File.join(results_dir, "#{timestamp}-default-comparison.json")
  
  system(
    "hyperfine",
    "--warmup", "1",
    "--runs", "3",
    "--export-json", json_file,
    "turbo_tests -n #{workers}",
    "rux -n #{workers}"
  )
  
  if File.exist?(json_file)
    data = JSON.parse(File.read(json_file))
    turbo = data["results"][0]
    rux = data["results"][1]
    diff = ((rux["mean"] - turbo["mean"]) / turbo["mean"] * 100).round(1)
    puts "\nDefault comparison:"
    puts "  turbo_tests: #{turbo["mean"].round(3)}s"
    puts "  rux:         #{rux["mean"].round(3)}s"
    puts "  Difference:  #{diff}% (rux is #{diff > 0 ? 'slower' : 'faster'})"
  end
  
  # Test 2: Force rux to use bare rspec
  puts "\n2. Testing rux with bare 'rspec' command..."
  json_file2 = File.join(results_dir, "#{timestamp}-rspec-comparison.json")
  
  system(
    "hyperfine",
    "--warmup", "1",
    "--runs", "3",
    "--export-json", json_file2,
    "turbo_tests -n #{workers}",
    %Q{rux -n #{workers} --command="rspec"}
  )
  
  if File.exist?(json_file2)
    data = JSON.parse(File.read(json_file2))
    turbo = data["results"][0]
    rux_rspec = data["results"][1]
    diff = ((rux_rspec["mean"] - turbo["mean"]) / turbo["mean"] * 100).round(1)
    puts "\nBare rspec comparison:"
    puts "  turbo_tests:      #{turbo["mean"].round(3)}s"
    puts "  rux with 'rspec': #{rux_rspec["mean"].round(3)}s"
    puts "  Difference:       #{diff}% (rux is #{diff > 0 ? 'slower' : 'faster'})"
  end
  
  # Test 3: Check actual command execution
  puts "\n3. Analyzing actual commands executed..."
  puts "\nturbo_tests command:"
  system("turbo_tests -n 1 --verbose spec/dx_spec.rb 2>&1 | grep 'Process 1:' | head -1")
  
  puts "\nrux default command:"
  system("rux spec --debug -n 1 spec/dx_spec.rb 2>&1 | grep 'executing command' | head -1")
  
  puts "\nrux with rspec command:"
  system(%Q{rux spec --debug -n 1 --command="rspec" spec/dx_spec.rb 2>&1 | grep 'executing command' | head -1})
end