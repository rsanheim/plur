#!/usr/bin/env bash

set -e

# Check if URL provided
if [ $# -eq 0 ]; then
    cat <<'EOF'
Usage: get-repo <github-url> [target-directory]

Quickly grab any GitHub repository for clean testing without git history.

Examples:
  get-repo https://github.com/example-org/example-project
  get-repo https://github.com/example-org/example-project my-test-dir
  get-repo git@github.com:example-org/example-project.git

What it does:
  - Converts HTTPS to SSH automatically for faster access
  - Shallow clone (--depth 1) for fast download
  - Removes .git directory for clean testing environment
  - Auto-generates directory names with timestamps

Requirements:
  - SSH access to GitHub configured
EOF
    exit 1
fi

REPO_URL="$1"
REPO_NAME=$(basename "$REPO_URL" .git)
TARGET_DIR=${2:-"$REPO_NAME-$(date +%s)"}

# Convert https URL to SSH if needed
if [[ "$REPO_URL" == https://github.com/* ]]; then
    SSH_URL=$(echo "$REPO_URL" | sed 's|https://github.com/|git@github.com:|g')
    if [[ "$SSH_URL" != *.git ]]; then
        SSH_URL="$SSH_URL.git"
    fi
else
    SSH_URL="$REPO_URL"
fi

echo "Getting clean repository environment..."
echo "Repository: $REPO_URL"
echo "Target directory: $TARGET_DIR"

# Shallow clone via SSH
echo "Cloning repository..."
git clone --depth 1 "$SSH_URL" "$TARGET_DIR"

# Remove .git directory for clean testing environment
echo "Removing .git directory..."
rm -rf "$TARGET_DIR/.git"

cat <<EOF
✅ Clean repository ready at: $TARGET_DIR

To test with plur (if Ruby project):
  cd $TARGET_DIR
  plur
EOF