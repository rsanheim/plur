#!/usr/bin/env ruby

require "bundler/setup"
Bundler.require(:default)
require_relative "../lib/plur/release"

def current_version
  `gh release list --limit 1 --json tagName -q '.[0].tagName' 2>/dev/null`.strip.tap { |v| return "(no releases)" if v.empty? }
end

def print_usage
  puts <<~USAGE
    Usage: script/release <command> <version> [options]

    Current version: #{current_version}

    Commands:
      prepare VERSION       Generate changelog entries for VERSION
      push VERSION          Tag and push VERSION (triggers GitHub Actions release)
      extract-notes VERSION Extract release notes from CHANGELOG.md (used by CI)

    Options:
      --dry-run             Show what would be done without executing

    Workflow:
      1. script/release prepare v0.14.0
      2. Review/edit CHANGELOG.md
      3. git add CHANGELOG.md && git commit -m "Changelog for v0.14.0"
      4. script/release push v0.14.0

    Version must be in format vX.Y.Z (e.g., v0.14.0, v1.0.0-rc1)
  USAGE
end

def validate_version!(version)
  unless version&.match?(/^v\d+\.\d+\.\d+(-.*)?$/)
    abort "Error: Invalid version #{version.inspect}. Version must be in format vX.Y.Z"
  end
end

command = ARGV[0]
version = ARGV[1]
dry_run = ARGV.include?("--dry-run")

case command
when "prepare"
  validate_version!(version)
  Plur::Release::Prepare.new(version, dry_run: dry_run).call

when "push"
  validate_version!(version)
  Plur::Release::Push.new(version, dry_run: dry_run).call

when "extract-notes"
  validate_version!(version)
  unless File.exist?("CHANGELOG.md")
    abort "Error: CHANGELOG.md not found in current directory"
  end

  content = File.read("CHANGELOG.md")
  version_escaped = Regexp.escape(version)

  if content =~ /^## #{version_escaped}.*?\n(.*?)(?=^## |\z)/m
    puts $1.strip
  else
    abort "Error: No changelog entry found for version #{version}"
  end

when "-h", "--help", "help", nil
  print_usage
  exit(command.nil? ? 1 : 0)

else
  puts "Unknown command: #{command}"
  print_usage
  exit 1
end
