#!/usr/bin/env ruby

require "optparse"
require_relative "../lib/plur/release"

options = {}

parser = OptionParser.new do |opts|
  opts.banner = "Usage: script/release VERSION [OPTIONS]"

  opts.on("-h", "--help", "Show this help message") do
    puts opts
    exit
  end

  opts.on("-a", "--automated", "Automated release - will not prompt for confirmation") do
    options[:automated] = true
  end

  opts.on("-d", "--draft", "Create a draft release (default)") do
    options[:draft] = true
  end

  opts.on("--no-draft", "Publish release immediately (not as draft)") do
    options[:draft] = false
  end

  opts.on("--extract-notes", "Extract release notes for VERSION from CHANGELOG.md and print to stdout") do
    options[:extract_notes] = true
  end

  opts.separator ""
  opts.separator "Examples:"
  opts.separator "  script/release v0.7.0                    # Create draft release v0.7.0"
  opts.separator "  script/release v1.0.0 --no-draft         # Create and publish release"
  opts.separator "  script/release v0.7.0 --automated        # Automated release (no prompts)"
  opts.separator "  script/release v0.7.0 --extract-notes    # Extract notes for v0.7.0"
  opts.separator ""
  opts.separator "Version must be in format vX.Y.Z"
end

# Extract version from ARGV[0] first (before parsing options)
version = ARGV.shift

# Then parse the remaining options
parser.parse!

unless version
  puts parser
  exit 1
end

unless version.match?(/^v\d+\.\d+\.\d+(-.*)?$/)
  puts "Error - invalid version #{version.inspect}. Version must be in format vX.Y.Z or vX.Y.Z-suffix (e.g., v0.7.0, v0.7.0-rc1)"
  exit 1
end

if options[:extract_notes]
  # Just extract and print the notes for this version
  unless File.exist?("CHANGELOG.md")
    abort "Error: CHANGELOG.md not found in current directory"
  end

  content = File.read("CHANGELOG.md")
  version_escaped = Regexp.escape(version)

  if content =~ /^## #{version_escaped}.*?\n(.*?)(?=^## |\z)/m
    puts $1.strip
  else
    abort "Error: No changelog entry found for version #{version}"
  end
else
  # Normal release flow
  Plur::Release.new(version, options).call
end
