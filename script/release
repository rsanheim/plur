#!/usr/bin/env ruby

# require "bundler/setup"
# Bundler.require(:default)
require_relative "../lib/plur/release"

def current_version
  `gh release list --limit 1 --json tagName -q '.[0].tagName' 2>/dev/null`.strip.tap { |v| return "(no releases)" if v.empty? }
end

def print_usage
  puts <<~USAGE
    Usage: script/release <command> <version> [options]

    Prepare changelog entries, validate release state, tag releases, and
    extract release notes from CHANGELOG.md for plur releases.

    Current version: #{current_version}

    Version format:
      Versions must use a v-prefixed semver tag:
        vX.Y.Z
        vX.Y.Z-rc.1

    Commands:
      prepare VERSION       Generate changelog entries for VERSION
      push VERSION          Tag and push VERSION (triggers GitHub Actions release)
      extract-notes VERSION Extract release notes from CHANGELOG.md (used by CI)

    Command details:
      prepare VERSION
        Verifies the current checkout matches origin/main, reads the latest
        GitHub release tag, scans git commit messages since that tag for PR
        numbers, fetches PR titles and URLs with gh, and updates CHANGELOG.md.
        Review the generated entry before committing it.

      push VERSION
        Verifies the current branch is main, verifies git status is clean,
        verifies CHANGELOG.md has an entry for VERSION, pushes main to origin,
        creates an annotated git tag, and pushes the tag to origin.

      extract-notes VERSION
        Prints the CHANGELOG.md section for VERSION. GitHub Actions uses this
        output as the GoReleaser release notes file.

    Options:
      --dry-run             Show what would be done without executing

    Full release process:
      See docs/development/release-process.md
  USAGE
end

def validate_version!(version)
  unless version&.match?(/^v\d+\.\d+\.\d+(-.*)?$/)
    abort "Error: Invalid version #{version.inspect}. Version must be in format vX.Y.Z"
  end
end

command = ARGV[0]
version = ARGV[1]
dry_run = ARGV.include?("--dry-run")

case command
when "prepare"
  validate_version!(version)
  Plur::Release::Prepare.new(version, dry_run: dry_run).call

when "push"
  validate_version!(version)
  Plur::Release::Push.new(version, dry_run: dry_run).call

when "extract-notes"
  validate_version!(version)
  unless File.exist?("CHANGELOG.md")
    abort "Error: CHANGELOG.md not found in current directory"
  end

  content = File.read("CHANGELOG.md")
  version_escaped = Regexp.escape(version)

  if content =~ /^## #{version_escaped}.*?\n(.*?)(?=^## |\z)/m
    puts $1.strip
  else
    abort "Error: No changelog entry found for version #{version}"
  end

when "-h", "--help", "help", nil
  print_usage
  exit(command.nil? ? 1 : 0)

else
  puts "Unknown command: #{command}"
  print_usage
  exit 1
end
