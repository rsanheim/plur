#!/bin/bash

set -e

show_help() {
    cat <<'EOF'
Usage: bench-checkpoint [options]

Creates a benchmark checkpoint with git commit info and consolidated results.

Options:
  -h, --help     Show this help message
  -n <num>       Number of worker processes (default: 8)

What it does:
  - Runs benchmarks on both rux-ruby and references/example-project
  - Tags results with current git commit SHA and message
  - Creates a consolidated checkpoint report
  - Useful for tracking performance over time

Requirements:
  - script/bench must be working
  - git repository

Output:
  Creates in ./results/:
  - checkpoint-<commit>-<timestamp>/
    - Individual benchmark results
    - checkpoint-report.md (consolidated report)
  - latest-checkpoint.md (symlink to latest report)

Examples:
  bench-checkpoint         # Create checkpoint with 8 workers
  bench-checkpoint -n 4    # Create checkpoint with 4 workers
EOF
}

# Default values
WORKERS=8

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help)
            show_help
            exit 0
            ;;
        -n)
            WORKERS="$2"
            shift 2
            ;;
        *)
            shift
            ;;
    esac
done


# Get git info
COMMIT_SHA=$(git rev-parse HEAD)
COMMIT_SHORT=$(git rev-parse --short HEAD)
COMMIT_MSG=$(git log -1 --pretty=%B | head -n1)
TIMESTAMP=$(date -u +"%Y-%m-%dT%H-%M-%SZ")

echo "Benchmark Checkpoint"
echo "==================="
echo "Commit: $COMMIT_SHORT - $COMMIT_MSG"
echo "Time: $TIMESTAMP"
echo ""

# Create checkpoint directory
CHECKPOINT_DIR="$RESULTS_DIR/checkpoint-${COMMIT_SHORT}-${TIMESTAMP}"
mkdir -p "$CHECKPOINT_DIR"

# Run default benchmarks (both projects)
./script/bench -n $WORKERS --default

# Copy latest results to checkpoint directory
cp "$RESULTS_DIR"/bench-rux-ruby-latest.* "$CHECKPOINT_DIR/"
cp "$RESULTS_DIR"/bench-example-project-latest.* "$CHECKPOINT_DIR/"

# Create consolidated report
REPORT_FILE="$CHECKPOINT_DIR/checkpoint-report.md"

cat > "$REPORT_FILE" <<EOF
# Benchmark Checkpoint Results

- **Commit**: $COMMIT_SHA
- **Message**: $COMMIT_MSG
- **Date**: $TIMESTAMP

## rux-ruby Results

EOF

# Add rux-ruby results
cat "$RESULTS_DIR/bench-rux-ruby-latest.md" >> "$REPORT_FILE"

cat >> "$REPORT_FILE" <<EOF

## references/example-project Results

EOF

# Add example-project results
cat "$RESULTS_DIR/bench-example-project-latest.md" >> "$REPORT_FILE"

# Extract performance comparison from JSON files using ruby
ruby -e '
require "json"

rux_ruby_data = JSON.parse(File.read("'$CHECKPOINT_DIR'/bench-rux-ruby-latest.json"))
dx_data = JSON.parse(File.read("'$CHECKPOINT_DIR'/bench-example-project-latest.json"))

def extract_times(data)
  turbo_time = data["results"].find { |r| r["command"].include?("turbo_tests") }["mean"]
  rux_time = data["results"].find { |r| r["command"].include?("rux") }["mean"]
  [turbo_time, rux_time]
end

puts "\n## Summary\n"

# rux-ruby
turbo, rux = extract_times(rux_ruby_data)
diff_percent = ((rux - turbo) / turbo * 100).round(1)
status = diff_percent > 0 ? "slower" : "faster"
puts "- **rux-ruby**: rux is #{diff_percent.abs}% #{status} than turbo_tests"

# example-project
turbo, rux = extract_times(dx_data)
diff_percent = ((rux - turbo) / turbo * 100).round(1)
status = diff_percent > 0 ? "slower" : "faster"
puts "- **references/example-project**: rux is #{diff_percent.abs}% #{status} than turbo_tests"
' >> "$REPORT_FILE"

# Create symlink to latest checkpoint
ln -sf "checkpoint-${COMMIT_SHORT}-${TIMESTAMP}/checkpoint-report.md" "$RESULTS_DIR/latest-checkpoint.md"

echo ""
echo "=== Checkpoint created ==="
echo "Directory: $CHECKPOINT_DIR/"
echo "Report: $REPORT_FILE"
echo ""
echo "View checkpoint:"
echo "  cat $RESULTS_DIR/latest-checkpoint.md"