#!/usr/bin/env ruby
# Clean up orphaned test tags (tags with no releases)

require "bundler/setup"
require "open3"
require "parallel"

def run_command(cmd)
  stdout, stderr, status = Open3.capture3(cmd)
  [stdout, stderr, status]
end

puts "Fetching remote test tags..."

stdout, _, status = run_command("git ls-remote --tags origin")
unless status.success?
  warn "Error fetching remote tags"
  exit 1
end

# Extract tag names matching test pattern
test_tags = []
stdout.each_line do |line|
  # Skip annotated tag references (the ^{} ones)
  next if line.include?("^{}")

  # Match tags like v0.10.4-XXXX-test or v0.10.4-test
  if line =~ %r{refs/tags/(v0\.\d+\.\d+(?:-\d+)?-test\d*)\s*$}
    test_tags << $1
  end
end

# Also check for v0.11.0 if it has no release
puts "\nChecking for v0.11.0 tag..."
if stdout.include?("refs/tags/v0.11.0")
  stdout_release, _, _ = run_command("gh release view v0.11.0 2>&1")
  if stdout_release.include?("release not found")
    puts "  Found orphaned v0.11.0 tag (no release)"
    test_tags << "v0.11.0"
  else
    puts "  v0.11.0 has a release, skipping"
  end
end

if test_tags.empty?
  puts "No orphaned test tags found!"
  exit 0
end

puts "\nFound #{test_tags.size} orphaned tags:"
puts "=" * 60
test_tags.first(20).each { |tag| puts tag }
puts "... (#{test_tags.size - 20} more)" if test_tags.size > 20
puts "=" * 60
puts "Total: #{test_tags.size} orphaned tags"

puts "\nThis will delete all of them from origin (remote only, local tags preserved)."
puts "Press ENTER to continue, or Ctrl+C to cancel..."
$stdin.gets

puts "\nDeleting remote tags in parallel (20 workers)..."

deleted = 0
failed = 0
mutex = Mutex.new
progress = 0

results = Parallel.map(test_tags, in_threads: 20) do |tag|
  _, stderr, status = run_command("git push origin :refs/tags/#{tag} 2>&1")

  result = if status.success?
    :deleted
  elsif stderr.include?("remote ref does not exist")
    :deleted
  else
    {error: tag, message: stderr}
  end

  mutex.synchronize do
    progress += 1
    print "\r[#{progress}/#{test_tags.size}] Deleting remote tags...".ljust(80)
  end

  result
end

results.each do |result|
  if result == :deleted
    deleted += 1
  else
    failed += 1
    puts "\n  ERROR deleting #{result[:error]}: #{result[:message]}"
  end
end

puts "\n\nCleanup complete!"
puts "  Deleted: #{deleted}"
puts "  Failed: #{failed}" if failed > 0

# Clean up local test tags too
puts "\nCleaning up local test tags..."
local_test_tags = `git tag | grep -E 'v0\\.10\\.4.*-test'`.split("\n")
if local_test_tags.any?
  local_test_tags.each { |tag| run_command("git tag -d #{tag}") }
  puts "  Deleted #{local_test_tags.size} local test tags"
else
  puts "  No local test tags to delete"
end

puts "\nDone!"
