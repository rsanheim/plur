# Example plur.toml configuration file
#
# Copy this file to .plur.toml in your project root or ~/.plur.toml for global settings.
#
# Configuration precedence (highest to lowest):
# 1. Command-line flags
# 2. Environment variables (PARALLEL_TEST_PROCESSORS, PLUR_DEBUG)
# 3. Config files (later files override earlier values):
#    - ~/.plur.toml (user-specific)
#    - .plur.toml (project-specific)
#    - PLUR_CONFIG_FILE (if set)
# 4. Built-in defaults

# =============================================================================
# GLOBAL SETTINGS
# =============================================================================

# Number of parallel workers to use
# Default: 4
workers = 4

# Enable colored output
# Default: true (auto-detected based on terminal support)
color = true

# Enable verbose output
# Default: false
verbose = false

# Default job to use (can be overridden with --use flag)
# Default: auto-detect based on project structure (spec/ → rspec, test/ → minitest)
use = "rspec"

# =============================================================================
# JOB CONFIGURATION
# Define test frameworks and custom jobs
# =============================================================================

# RSpec job configuration
[job.rspec]
# Command array to run (targets are appended automatically)
# Default: ["bundle", "exec", "rspec"]
cmd = ["bin/rspec"]

# Pattern for finding test files
# Default: "spec/**/*_spec.rb" (built-in for job.rspec)
target_pattern = "spec/**/*_spec.rb"

# Minitest job configuration
[job.minitest]
cmd = ["bundle", "exec", "ruby", "-Itest"]
target_pattern = "test/**/*_test.rb"

# Rails and Rake command jobs
# Built-in commands are ["bin/rails"] and ["bundle", "exec", "rake"].
# Use -- to pass Rails/Rake-specific flags:
#   plur rake -n 1 -- --tasks
#   plur rails db:migrate -n 4 -- --trace

# Custom job example - integration tests only
[job.integration]
framework = "rspec"
cmd = ["bin/rspec", "--tag", "integration"]
target_pattern = "spec/integration/**/*_spec.rb"

# Custom no-arg build job
[job.build]
cmd = ["bin/rake", "install"]

# =============================================================================
# WATCH MODE CONFIGURATION
# Settings for 'plur watch' - maps source files to tests
# =============================================================================

# Watch lib files and run corresponding specs
# Named watch mappings must be unique if you define them.
[[watch]]
name = "lib-to-spec"
source = "lib/**/*.rb"
targets = ["spec/{{match}}_spec.rb"]
jobs = ["rspec"]

# Watch spec files and run themselves
[[watch]]
name = "spec-files"
source = "spec/**/*_spec.rb"
jobs = ["rspec"]

# Watch source files and run a no-arg build command
[[watch]]
name = "go-build"
source = "**/*.go"
no_targets = true
jobs = ["build"]
reload = true

# Watch app files (Rails) and run corresponding specs
[[watch]]
name = "app-to-spec"
source = "app/**/*.rb"
targets = ["spec/{{match}}_spec.rb"]
jobs = ["rspec"]
